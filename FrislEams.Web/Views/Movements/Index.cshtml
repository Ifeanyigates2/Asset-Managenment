@model List<FrislEams.Web.Services.MovementRecord>
@{ ViewData["Title"] = "Movements"; }

<div class="page-header">
    <div class="page-title">
        <h1>Movements</h1>
        <p class="page-subtitle">Recent asset assignments, transfers, and status changes</p>
    </div>
</div>

<div class="info-card">
    <table class="data-table">
        <thead>
            <tr><th>Date</th><th>Asset</th><th>Type</th><th>Detail</th><th>By</th></tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OccurredAt.ToString("dd MMM yyyy HH:mm")</td>
                <td><strong>@item.AssetTag</strong><br /><span class="text-muted">@item.AssetName</span></td>
                <td>@item.MovementType</td>
                <td>@item.Detail</td>
                <td>@item.Actor</td>
            </tr>
        }
        </tbody>
    </table>
</div>
