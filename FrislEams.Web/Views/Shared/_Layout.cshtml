@{
    var sessionPortal = Context.Session.GetString("UserPortal")
        ?? FrislEams.Web.Services.PortalService.GetPortalForRole(Context.Session.GetString("UserRole"));
    var portalKey = sessionPortal?.ToLowerInvariant() ?? "backoffice";
    var portalTheme = $"portal-theme-{portalKey}";
    var sidebarPartial = sessionPortal switch
    {
        "Admin" => "_Sidebars/AdminSidebar",
        "Auditor" => "_Sidebars/AuditorSidebar",
        "Staff" => "_Sidebars/StaffSidebar",
        _ => "_Sidebars/BackofficeSidebar"
    };
    var isDashboard = (Context.Request.Path.Value ?? "").Contains("/Portal/", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – " : "")FRISL EAMS | First Registrars</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portal-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portals/portal-@(portalKey).css" asp-append-version="true" />
</head>
<body class="portal-app @portalTheme">
    <div class="portal-app-shell">
        @await Html.PartialAsync(sidebarPartial)
        <div class="portal-sidebar-backdrop" id="portalSidebarBackdrop" aria-hidden="true"></div>

        <div class="portal-main">
            <header class="portal-main-header portal-main-header-@portalKey">
                <div class="portal-header-left">
                    <button type="button" class="portal-menu-toggle" id="portalMenuToggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="portalSidebar">
                        <span class="portal-menu-bar"></span>
                        <span class="portal-menu-bar"></span>
                        <span class="portal-menu-bar"></span>
                    </button>
                    <img src="~/firstregistrars-logo.png" alt="First Registrars" class="portal-header-logo" />
                    <div class="portal-header-titles">
                        <span class="portal-header-name">@sessionPortal Portal</span>
                        <span class="portal-header-tag">RFID-enabled · Role-based access · Secure</span>
                    </div>
                </div>
                <div class="portal-header-right">
                    <span class="portal-header-meta">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
                    <a href="/Account/Logout" class="portal-logout-btn portal-logout-btn-header">Logout</a>
                </div>
            </header>

            <main class="portal-main-content">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success"><span>✓</span> @success</div>
                }
                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-error"><span>⚠</span> @error</div>
                }
                @RenderBody()
                @if (isDashboard)
                {
                    @await Html.PartialAsync("_PortalFeatures")
                }
            </main>

            <footer class="portal-main-footer">
                &copy; @DateTime.Now.Year First Registrars &amp; Investor Services Ltd. · @sessionPortal Portal
            </footer>
        </div>
    </div>
    <script>
        (function () {
            var toggle = document.getElementById('portalMenuToggle');
            var backdrop = document.getElementById('portalSidebarBackdrop');
            var sidebar = document.getElementById('portalSidebar');
            if (!toggle || !backdrop || !sidebar) return;

            function setOpen(open) {
                document.body.classList.toggle('portal-nav-open', open);
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
                backdrop.setAttribute('aria-hidden', open ? 'false' : 'true');
            }

            toggle.addEventListener('click', function () {
                setOpen(!document.body.classList.contains('portal-nav-open'));
            });

            backdrop.addEventListener('click', function () { setOpen(false); });

            sidebar.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', function () { setOpen(false); });
            });

            window.addEventListener('resize', function () {
                if (window.innerWidth > 768) setOpen(false);
            });
        })();
    </script>
</body>
</html>
