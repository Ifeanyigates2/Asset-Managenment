@model FrislEams.Web.Models.UserCreateVm
@{
    ViewData["Title"] = "Create User";
    var departments = ViewBag.Departments as List<FrislEams.Web.Models.Department> ?? new();
    var branches = ViewBag.Branches as List<FrislEams.Web.Models.Location> ?? new();
    var roles = ViewBag.RoleOptions as string[] ?? Array.Empty<string>();
}

<div class="page-header">
    <div class="page-title">
        <h1>Create User</h1>
        <p class="page-subtitle">Complete employee details and assign a temporary password</p>
    </div>
</div>

<form asp-action="Create" method="post" class="form-card">
    @Html.AntiForgeryToken()
    <div class="form-grid">
        <div class="form-group"><label asp-for="EmployeeId"></label><input asp-for="EmployeeId" class="form-control" required /></div>
        <div class="form-group"><label asp-for="DisplayName">Name</label><input asp-for="DisplayName" class="form-control" required /></div>
        <div class="form-group"><label asp-for="Email"></label><input asp-for="Email" type="email" class="form-control" required /></div>
        <div class="form-group"><label asp-for="PhoneNumber"></label><input asp-for="PhoneNumber" class="form-control" /></div>
        <div class="form-group"><label asp-for="Designation"></label><input asp-for="Designation" class="form-control" /></div>
        <div class="form-group">
            <label asp-for="DepartmentId">Department</label>
            <select asp-for="DepartmentId" class="form-control">
                <option value="">Select department</option>
                @foreach (var d in departments) { <option value="@d.Id">@d.Name</option> }
            </select>
        </div>
        <div class="form-group">
            <label asp-for="BranchLocationId">Branch</label>
            <select asp-for="BranchLocationId" class="form-control">
                <option value="">Select branch</option>
                @foreach (var b in branches) { <option value="@b.Id">@b.Name</option> }
            </select>
        </div>
        <div class="form-group">
            <label asp-for="Role">User Role</label>
            <select asp-for="Role" class="form-control">
                @foreach (var r in roles) { <option value="@r">@r</option> }
            </select>
        </div>
        <div class="form-group"><label asp-for="TemporaryPassword">Temporary Password</label><input asp-for="TemporaryPassword" type="password" class="form-control" required /></div>
    </div>
    <button type="submit" class="btn btn-primary">Save User</button>
    <a asp-action="Index" class="btn btn-outline">Cancel</a>
</form>
