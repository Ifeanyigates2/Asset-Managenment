@{
    Layout = "_LoginLayout";
    var portal = ViewBag.Portal as string ?? "Backoffice";
    var demoUser = ViewBag.DemoUser as string ?? portal;
    var portalDesc = portal switch
    {
        "Admin" => "System administration, user management, vendors, and approvals",
        "Auditor" => "Audits, compliance verification, and asset reporting",
        "Staff" => "Assignments, requests, repairs, and loan workflows",
        _ => "Asset administration, operations, and master data management"
    };
}

<div class="signin-page">
    <div class="signin-shell">
        <section class="signin-panel signin-panel-solo">
            <div class="signin-card signin-card-minimal">
                <div class="signin-branding">
                    <img src="~/firstregistrars-logo.png" alt="First Registrars &amp; Investor Services" class="signin-logo" />
                    <div class="signin-subtitle">Enterprise Asset Management System</div>
                </div>

                <div class="signin-title-wrap">
                    <div class="signin-title">@portal Portal</div>
                    <div class="signin-desc">@portalDesc</div>
                </div>

                <div class="signin-gold-bar"></div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-error signin-alert">⚠️ @ViewBag.Error</div>
                }

                <form method="post" action="/Account/Login/@portal?returnUrl=@ViewBag.ReturnUrl" class="signin-form" id="loginForm">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" id="username" name="username" class="form-control signin-input" placeholder="Enter your @portal username"
                               autocomplete="username" autofocus required />
                    </div>
                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" id="password" name="password" class="form-control signin-input" placeholder="Enter your password"
                               autocomplete="current-password" required />
                    </div>
                    <button type="submit" class="signin-btn">Sign In to @portal Portal <span aria-hidden="true">→</span></button>
                </form>

                <div class="signin-demo-note signin-demo-note-minimal">
                    <div class="signin-demo-head">
                        <strong>Demo - Click to Auto-Fill</strong>
                    </div>
                    <div class="signin-demo-grid signin-demo-grid-inline signin-demo-grid-portals">
                        <button type="button" class="role-pill role-pill-minimal portal-demo-btn">
                            <span class="role-pill-title">@demoUser</span>
                        </button>
                    </div>
                </div>

                <div class="portal-back-link">
                    <a href="/Account/Login@(ViewBag.ReturnUrl != null ? $"?returnUrl={Uri.EscapeDataString(ViewBag.ReturnUrl as string ?? "")}" : "")">← Back to sign in</a>
                </div>

                <div class="signin-footer">
                    &copy; @DateTime.Now.Year First Registrars &amp; Investor Services Ltd.<br />
                    All rights reserved. Authorised access only.
                </div>
            </div>
        </section>
    </div>
</div>

<script>
    const demoPassword = '@(portal == "Staff" ? "Staff1" : portal == "Auditor" ? "auditor1" : portal == "Admin" ? "Admin1" : "Washington1")';
    const demoUser = '@demoUser';
    document.querySelector('.portal-demo-btn')?.addEventListener('click', () => {
        document.getElementById('username').value = demoUser;
        document.getElementById('password').value = demoPassword;
    });
</script>
